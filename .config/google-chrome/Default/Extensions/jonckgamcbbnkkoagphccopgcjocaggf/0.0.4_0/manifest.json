{
   "background": {
      "persistent": true,
      "scripts": [ "src/bg/background.js" ]
   },
   "content_security_policy": "connect-src https://api.crxcavator.io; img-src https://lh3.googleusercontent.com; script-src 'self'; object-src 'self';",
   "description": "Gathers user extension data for CRXcavator",
   "icons": {
      "128": "icons/128x128.png",
      "16": "icons/16x16.png",
      "48": "icons/48x48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "CRXcavator Gatherer",
   "permissions": [ "management", "identity", "identity.email", "alarms", "storage", "activeTab", "notifications", "https://chrome.google.com/webstore/*" ],
   "storage": {
      "managed_schema": "managed_policy_schema.json"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.0.4",
   "web_accessible_resources": [ "src/pages/*", "src/ui/*" ]
}
